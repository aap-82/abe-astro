---
import Section from './Section.astro';
import Container from './Container.astro';
import Button from './Button.astro';

import type { SectionSurface } from './Section.astro';

export type HeroVariant = 'primary' | 'course' | 'bundle' | 'minimal';

export interface Props {
  overline?: string;
  headline: string;
  subhead?: string;
  primaryCtaLabel?: string;
  primaryCtaHref?: string;
  secondaryCtaLabel?: string;
  secondaryCtaHref?: string;
  imageSrc?: string;
  imageAlt?: string;
  variant?: HeroVariant;
  surface?: SectionSurface;
  eager?: boolean;
}

const {
  overline,
  headline,
  subhead,
  primaryCtaLabel,
  primaryCtaHref,
  secondaryCtaLabel,
  secondaryCtaHref,
  imageSrc,
  imageAlt = '',
  variant = 'primary',
  surface = 'page',
  eager = true
} = Astro.props;

const showMedia = variant !== 'minimal' && Boolean(imageSrc);
const onDark = surface === 'brand' || surface === 'inverse';
---

<Section surface={surface} padding="l" class="abe-hero">
  <Container width="content">
    <div class:list={['abe-hero__grid', showMedia && 'abe-hero__grid--split']}>
      <div class="abe-hero__copy">
        {overline && <span class="abe-hero__overline">{overline}</span>}
        <h1 class="abe-hero__headline">{headline}</h1>
        {subhead && <p class="abe-hero__subhead">{subhead}</p>}

        {(primaryCtaLabel || secondaryCtaLabel) && (
          <div class="abe-hero__ctas">
            {primaryCtaLabel && (
              <Button
                label={primaryCtaLabel}
                href={primaryCtaHref}
                size="lg"
                variant="primary"
              />
            )}
            {secondaryCtaLabel && (
              <Button
                label={secondaryCtaLabel}
                href={secondaryCtaHref}
                size="lg"
                variant="tertiary"
              />
            )}
          </div>
        )}
      </div>

      {showMedia && imageSrc && (
        <img
          src={imageSrc}
          alt={imageAlt}
          loading={eager ? 'eager' : 'lazy'}
          decoding="async"
          fetchpriority={eager ? 'high' : 'auto'}
          class="abe-hero__image"
        />
      )}
    </div>
  </Container>
</Section>

<style define:vars={{ onDarkOverline: onDark ? 'var(--text-inverse)' : 'var(--text-brand)', onDarkText: onDark ? 'var(--text-inverse)' : 'var(--text-body)', onDarkSub: onDark ? 'var(--text-inverse)' : 'var(--text-subtle)' }}>
  .abe-hero__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-48);
    align-items: center;
  }

  @media (min-width: 900px) {
    .abe-hero__grid--split {
      grid-template-columns: 1.1fr 1fr;
      gap: var(--space-64);
    }
  }

  .abe-hero__copy {
    display: flex;
    flex-direction: column;
    gap: var(--space-24);
  }

  .abe-hero__overline {
    font-family: var(--font-body);
    font-size: 14px;
    line-height: 20px;
    font-weight: 600;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: var(--onDarkOverline);
  }

  .abe-hero__headline {
    font-family: var(--font-heading);
    font-size: clamp(36px, 5vw, 48px);
    line-height: 1.15;
    font-weight: 700;
    letter-spacing: -0.015em;
    margin: 0;
    color: var(--onDarkText);
  }

  .abe-hero__subhead {
    font-family: var(--font-body);
    font-size: 18px;
    line-height: 28px;
    font-weight: 400;
    margin: 0;
    max-width: 560px;
    color: var(--onDarkSub);
  }

  .abe-hero__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-16);
    margin-top: var(--space-8);
  }

  .abe-hero__image {
    width: 100%;
    height: auto;
    border-radius: var(--radius-lg);
    box-shadow: var(--elevation-lg);
    object-fit: cover;
  }
</style>
