---
// ExpertEditorial — large 5fr/7fr layout for the Framer /experts
// treatment. Portrait on the left with a role-overlay chip pinned to
// the bottom-left corner. Right column: eyebrow, 44 px H2, a role-line
// with a bottom-border and optional award-badge row, long-form bio,
// optional pullquote, 3-column credential grid, and an arrow CTA.
//
// Accepts a `person` prop matching the PersonRecord shape from
// lib/people.ts, so pages can pass it straight from `byRole('developer')`.

import type { PersonRecord } from '../lib/people';
import EyebrowLabel from './EyebrowLabel.astro';
import AwardBadge from './AwardBadge.astro';
import Pullquote from './Pullquote.astro';
import CredentialColumns from './CredentialColumns.astro';

export interface Props {
  person: PersonRecord;
  /** Small eyebrow line above the name (e.g. "COURSE DEVELOPER"). */
  eyebrow?: string;
  /** Optional pullquote body. If provided, renders the Pullquote block. */
  quote?: string;
  /** Cite line for the pullquote. */
  quoteCite?: string;
  /** Up to 3 award-style pills shown on the role line. */
  awards?: string[];
  /** Up to 3 credential columns (heading + body each). */
  credentials?: { heading: string; body: string }[];
  /** Text for the arrow CTA. Default "Read full profile". */
  ctaLabel?: string;
  /** Alternate tint the whole section (off-white bg vs white). */
  tone?: 'light' | 'off-white';
  class?: string;
}

const {
  person,
  eyebrow,
  quote,
  quoteCite,
  awards = [],
  credentials = [],
  ctaLabel = 'Read full profile',
  tone = 'light',
  class: className = ''
} = Astro.props;

const classes = [
  'abe-editorial',
  `abe-editorial--${tone}`,
  className
].filter(Boolean).join(' ');
---

<section class={classes}>
  <div class="abe-editorial__inner">
    <div class="abe-editorial__portrait">
      {person.image
        ? <img src={person.image} alt={person.name} loading="lazy" decoding="async" />
        : <div class="abe-editorial__portrait-placeholder" aria-hidden="true" />
      }
      <span class="abe-editorial__role-chip">{person.jobTitle}</span>
    </div>

    <div class="abe-editorial__body">
      {eyebrow && <EyebrowLabel>{eyebrow}</EyebrowLabel>}
      <h2 class="abe-editorial__name">{person.name}</h2>
      <p class="abe-editorial__role-line">
        <span class="abe-editorial__role">{person.credentialLine}</span>
        {person.affiliation && (
          <>
            <span aria-hidden="true" class="abe-editorial__dot">·</span>
            <span class="abe-editorial__affiliation">{person.affiliation}</span>
          </>
        )}
      </p>

      {awards.length > 0 && (
        <div class="abe-editorial__awards">
          {awards.map((a) => <AwardBadge>{a}</AwardBadge>)}
        </div>
      )}

      <div class="abe-editorial__bio">
        <slot>
          <p>{person.bio}</p>
        </slot>
      </div>

      {quote && <Pullquote cite={quoteCite}>{quote}</Pullquote>}

      {credentials.length > 0 && <CredentialColumns items={credentials} />}

      {person.profileUrl && (
        <a class="abe-editorial__cta" href={person.profileUrl}>
          {ctaLabel}
          <span aria-hidden="true" class="abe-editorial__cta-arrow">→</span>
        </a>
      )}
    </div>
  </div>
</section>

<style>
  .abe-editorial { padding: var(--space-80) 0; }
  .abe-editorial--light     { background: var(--surface-page); }
  .abe-editorial--off-white { background: var(--color-neutral-50); }

  .abe-editorial__inner {
    max-width: var(--container-editorial);
    margin: 0 auto;
    padding: 0 var(--space-24);
    display: grid;
    grid-template-columns: 5fr 7fr;
    gap: var(--space-64);
    align-items: start;
  }

  /* Portrait */
  .abe-editorial__portrait {
    position: relative;
    aspect-ratio: 4 / 5;
    border-radius: var(--radius-md);
    overflow: hidden;
    box-shadow: var(--shadow-medium);
    background: linear-gradient(135deg, #f3f4f6 0%, #e2e8f0 100%);
  }
  .abe-editorial__portrait img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .abe-editorial__portrait-placeholder {
    position: absolute; inset: 0;
    background: linear-gradient(135deg, #f3f4f6 0%, #e2e8f0 100%);
  }
  .abe-editorial__role-chip {
    position: absolute;
    left: var(--space-16);
    bottom: var(--space-16);
    background: var(--color-neutral-900);
    color: #ffffff;
    padding: 6px 10px;
    border-radius: 3px;
    font-family: var(--font-heading);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    line-height: 1.2;
  }

  /* Body */
  .abe-editorial__body { display: flex; flex-direction: column; gap: var(--space-16); }
  .abe-editorial__name {
    font-family: var(--font-heading);
    font-size: 44px;
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.5px;
    margin: 0;
    color: var(--text-body);
  }
  .abe-editorial__role-line {
    font-family: var(--font-body);
    font-size: 15px;
    color: var(--text-subtle);
    padding-bottom: var(--space-12);
    border-bottom: 1px solid var(--border-subtle);
    margin: 0;
  }
  .abe-editorial__dot { margin: 0 var(--space-8); color: var(--text-muted); }
  .abe-editorial__awards {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-8);
  }
  .abe-editorial__bio {
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1.75;
    color: var(--text-body);
  }
  .abe-editorial__bio :global(p) { margin: 0 0 var(--space-16); }
  .abe-editorial__bio :global(p:last-child) { margin-bottom: 0; }

  /* Arrow CTA */
  .abe-editorial__cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-8);
    margin-top: var(--space-16);
    font-family: var(--font-heading);
    font-size: 15px;
    font-weight: 700;
    color: var(--color-maroon-700);
    text-decoration: none;
    padding-bottom: 4px;
    border-bottom: 2px solid var(--color-maroon-700);
    align-self: flex-start;
    transition: gap var(--duration-base) var(--ease-standard);
  }
  .abe-editorial__cta:hover { gap: var(--space-12); }
  .abe-editorial__cta-arrow { font-size: 16px; }

  @media (max-width: 900px) {
    .abe-editorial { padding: var(--space-64) 0; }
    .abe-editorial__inner {
      grid-template-columns: 1fr;
      gap: var(--space-32);
    }
    .abe-editorial__portrait { max-width: 420px; }
    .abe-editorial__name { font-size: 30px; }
  }
</style>
