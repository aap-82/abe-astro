---
// Card — static by default, interactive lift via CSS :hover.
// Renders as <a> when href is supplied, else <div>.

export type CardSurface = 'page' | 'subtle' | 'elevated' | 'brand-tint';
export type CardPadding = 'sm' | 'md' | 'lg';
export type CardRadius = 'sm' | 'md' | 'lg';
export type CardElevation = '0' | 'sm' | 'md';

export interface Props {
  surface?: CardSurface;
  padding?: CardPadding;
  radius?: CardRadius;
  elevation?: CardElevation;
  showBorder?: boolean;
  interactive?: boolean;
  eyebrow?: string;
  title?: string;
  body?: string;
  href?: string;
  class?: string;
}

const {
  surface = 'elevated',
  padding = 'md',
  radius = 'md',
  elevation = 'sm',
  showBorder = true,
  interactive = false,
  eyebrow,
  title,
  body,
  href,
  class: className = ''
} = Astro.props;

const hasCopy = Boolean(eyebrow || title || body);

const classes = [
  'abe-card',
  `abe-card--surface-${surface}`,
  `abe-card--pad-${padding}`,
  `abe-card--radius-${radius}`,
  `abe-card--elev-${elevation}`,
  showBorder ? 'abe-card--bordered' : '',
  interactive || href ? 'abe-card--interactive' : '',
  className
]
  .filter(Boolean)
  .join(' ');
---

{href ? (
  <a href={href} class={classes}>
    {hasCopy && (
      <div class="abe-card__copy">
        {eyebrow && <span class="abe-card__eyebrow">{eyebrow}</span>}
        {title && <h3 class="abe-card__title">{title}</h3>}
        {body && <p class="abe-card__body">{body}</p>}
      </div>
    )}
    <slot />
  </a>
) : (
  <div class={classes}>
    {hasCopy && (
      <div class="abe-card__copy">
        {eyebrow && <span class="abe-card__eyebrow">{eyebrow}</span>}
        {title && <h3 class="abe-card__title">{title}</h3>}
        {body && <p class="abe-card__body">{body}</p>}
      </div>
    )}
    <slot />
  </div>
)}

<style>
  .abe-card {
    display: block;
    color: inherit;
    text-decoration: none;
    transition:
      box-shadow var(--duration-base) var(--ease-standard),
      transform var(--duration-base) var(--ease-standard);
  }

  /* Surfaces */
  .abe-card--surface-page       { background: var(--surface-page); }
  .abe-card--surface-subtle     { background: var(--surface-subtle); }
  .abe-card--surface-elevated   { background: var(--surface-page); }
  .abe-card--surface-brand-tint { background: var(--surface-brand-tint); }

  /* Padding */
  .abe-card--pad-sm { padding: var(--space-16); }
  .abe-card--pad-md { padding: var(--space-24); }
  .abe-card--pad-lg { padding: var(--space-32); }

  /* Radius */
  .abe-card--radius-sm { border-radius: var(--radius-sm); }
  .abe-card--radius-md { border-radius: var(--radius-md); }
  .abe-card--radius-lg { border-radius: var(--radius-lg); }

  /* Elevation */
  .abe-card--elev-0  { box-shadow: none; }
  .abe-card--elev-sm { box-shadow: var(--elevation-sm); }
  .abe-card--elev-md { box-shadow: var(--elevation-md); }

  .abe-card--bordered {
    border: 1px solid var(--border-subtle);
  }

  .abe-card--interactive {
    cursor: pointer;
  }
  .abe-card--interactive:hover {
    box-shadow: var(--elevation-md);
    transform: translateY(-2px);
  }
  .abe-card--interactive:focus-visible {
    box-shadow: var(--elevation-brand-focus);
    outline: none;
  }

  /* Copy block */
  .abe-card__copy {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }
  .abe-card__copy:not(:only-child) {
    margin-bottom: var(--space-16);
  }

  .abe-card__eyebrow {
    font-family: var(--font-body);
    font-size: 12px;
    line-height: 16px;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--text-brand);
  }

  .abe-card__title {
    font-family: var(--font-heading);
    font-size: 20px;
    line-height: 28px;
    font-weight: 700;
    letter-spacing: -0.005em;
    margin: 0;
    color: var(--text-body);
  }

  .abe-card__body {
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 24px;
    margin: 0;
    color: var(--text-subtle);
  }
</style>
