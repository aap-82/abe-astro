---
// Callout — inline content block used throughout course pages to flag
// verified claims, regulatory watch-outs, legal citations, cross-references,
// and bundle upsells.
//
// Visual treatment: outlined card. A 1 px coloured border on a white
// background identifies the variant; the label pill carries the tint;
// the title picks up the variant colour while body copy stays on the
// default body colour so long-form prose reads cleanly. SSR-only.

const DEFAULT_LABELS = {
  verified: 'VERIFIED',
  warning:  'WATCH-OUT',
  legal:    'LEGAL',
  crossref: 'RELATED',
  bundle:   'BUNDLE'
};

const {
  variant,
  title,
  icon,
  sourceUrl,
  sourceLabel,
  class: className = ''
} = Astro.props;

const label = icon === undefined
  ? DEFAULT_LABELS[variant as keyof typeof DEFAULT_LABELS]
  : icon;

let hostname = '';
if (sourceUrl) {
  try {
    hostname = new URL(sourceUrl).hostname.replace(/^www\./, '');
  } catch (_err) {
    hostname = sourceUrl;
  }
}

const classes = [
  'abe-callout',
  `abe-callout--${variant}`,
  className
]
  .filter(Boolean)
  .join(' ');
---

<aside class={classes} role="note" aria-label={title ?? `${variant} callout`}>
  {(label || title) && (
    <div class="abe-callout__head">
      {label && <span class="abe-callout__tag" aria-hidden="true">{label}</span>}
      {title && <p class="abe-callout__title">{title}</p>}
    </div>
  )}
  <div class="abe-callout__content">
    <slot />
  </div>
  {sourceUrl && (
    <p class="abe-callout__source">
      <span class="abe-callout__source-label">Source:</span>
      <a href={sourceUrl} rel="noopener noreferrer nofollow" target="_blank">
        {sourceLabel ?? hostname}
      </a>
    </p>
  )}
</aside>

<style>
  .abe-callout {
    background: var(--surface-page);
    border: 1px solid transparent;
    border-radius: var(--radius-md);
    padding: var(--space-16) var(--space-24);
    margin: var(--space-24) 0;
    font-family: var(--font-body);
    color: var(--text-body);
  }

  .abe-callout__head {
    display: flex;
    align-items: center;
    gap: var(--space-12);
    flex-wrap: wrap;
    margin-bottom: var(--space-4);
  }

  .abe-callout__tag {
    display: inline-flex;
    align-items: center;
    height: 22px;
    padding: 0 var(--space-8);
    border-radius: var(--radius-xs);
    font-family: var(--font-body);
    font-size: 11px;
    line-height: 16px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    white-space: nowrap;
    flex: 0 0 auto;
  }

  .abe-callout__title {
    font-family: var(--font-heading);
    font-size: 15px;
    line-height: 20px;
    font-weight: 700;
    margin: 0;
  }

  .abe-callout__content {
    font-size: 15px;
    line-height: 22px;
    color: var(--text-body);
  }

  .abe-callout__content :global(*:first-child) { margin-top: 0; }
  .abe-callout__content :global(*:last-child)  { margin-bottom: 0; }

  .abe-callout__content :global(p) {
    margin: 0 0 var(--space-8);
  }

  .abe-callout__content :global(a) {
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .abe-callout__source {
    font-size: 13px;
    line-height: 18px;
    margin: var(--space-8) 0 0;
    color: var(--text-subtle);
  }

  .abe-callout__source-label {
    font-weight: 600;
    margin-right: var(--space-4);
  }

  .abe-callout__source a {
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  /* Variant: verified */
  .abe-callout--verified {
    border-color: var(--color-success-500);
  }
  .abe-callout--verified .abe-callout__tag {
    background: var(--color-success-100);
    color: var(--color-success-700);
  }
  .abe-callout--verified .abe-callout__title {
    color: var(--color-success-700);
  }

  /* Variant: warning */
  .abe-callout--warning {
    border-color: var(--color-warning-500);
  }
  .abe-callout--warning .abe-callout__tag {
    background: var(--color-warning-100);
    color: var(--color-warning-700);
  }
  .abe-callout--warning .abe-callout__title {
    color: var(--color-warning-700);
  }

  /* Variant: legal */
  .abe-callout--legal {
    border-color: var(--color-info-500);
  }
  .abe-callout--legal .abe-callout__tag {
    background: var(--color-info-100);
    color: var(--color-info-700);
  }
  .abe-callout--legal .abe-callout__title {
    color: var(--color-info-700);
  }

  /* Variant: crossref */
  .abe-callout--crossref {
    border-color: var(--color-neutral-400);
  }
  .abe-callout--crossref .abe-callout__tag {
    background: var(--color-neutral-100);
    color: var(--color-neutral-800);
  }
  .abe-callout--crossref .abe-callout__title {
    color: var(--color-neutral-900);
  }

  /* Variant: bundle */
  .abe-callout--bundle {
    border-color: var(--color-maroon-700);
  }
  .abe-callout--bundle .abe-callout__tag {
    background: var(--color-maroon-100);
    color: var(--color-maroon-800);
  }
  .abe-callout--bundle .abe-callout__title {
    color: var(--color-maroon-800);
  }
</style>
