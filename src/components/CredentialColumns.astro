---
// CredentialColumns — 3-up grid of credential / stat / publication
// entries. Each column has a top border, a bold heading in Archivo, and
// a short slate-body description. Used inside ExpertEditorial and also
// reusable standalone on authority pages.

export interface CredentialItem {
  heading: string;
  body: string;
}

export interface Props {
  items: CredentialItem[];
  class?: string;
}

const { items, class: className = '' } = Astro.props;
const classes = ['abe-credcols', className].filter(Boolean).join(' ');
---

<div class={classes} role="list">
  {items.map((item) => (
    <div class="abe-credcols__col" role="listitem">
      <h3 class="abe-credcols__heading">{item.heading}</h3>
      <p class="abe-credcols__body">{item.body}</p>
    </div>
  ))}
</div>

<style>
  .abe-credcols {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-32);
    margin-top: var(--space-24);
  }
  .abe-credcols__col {
    padding-top: var(--space-16);
    border-top: 1px solid var(--border-subtle);
  }
  .abe-credcols__heading {
    font-family: var(--font-heading);
    font-size: 16px;
    font-weight: 700;
    line-height: 1.3;
    margin: 0 0 var(--space-8);
    color: var(--text-body);
  }
  .abe-credcols__body {
    font-family: var(--font-body);
    font-size: 13px;
    line-height: 1.6;
    color: var(--text-subtle);
    margin: 0;
  }
  @media (max-width: 720px) {
    .abe-credcols { grid-template-columns: 1fr; gap: var(--space-16); }
  }
</style>
