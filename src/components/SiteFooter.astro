---
// Site footer — company info, site nav, RTO/ASQA disclosure,
// legal links, copyright. Pure HTML/CSS.

import { SITE, RTO_PARTNERS, REGULATOR_RECOGNITIONS } from '../lib/site';

const year = new Date().getFullYear();
---

<footer class="abe-footer" role="contentinfo">
  <div class="abe-footer__inner">
    <div class="abe-footer__grid">

      <div class="abe-footer__col abe-footer__col--brand">
        <div class="abe-footer__logo">
          <span class="abe-footer__logo-text">ABE</span>
          <span class="abe-footer__logo-sub">Education</span>
        </div>
        <p class="abe-footer__tagline">
          Online Owner Builder and CPD training since 2007 — approved by
          state regulators, delivered in partnership with registered RTOs.
        </p>
        <address class="abe-footer__contact">
          <a href={`tel:${SITE.phone}`}>1300 000 000</a><br />
          <a href={`mailto:${SITE.email}`}>{SITE.email}</a>
        </address>
      </div>

      <nav class="abe-footer__col" aria-label="Footer navigation">
        <h2 class="abe-footer__heading">Training</h2>
        <ul class="abe-footer__list">
          <li><a href="/owner-builder">Owner Builder courses</a></li>
          <li><a href="/cpd">CPD training</a></li>
          <li><a href="/white-card">White Card</a></li>
          <li><a href="/asbestos">Asbestos awareness</a></li>
        </ul>
      </nav>

      <nav class="abe-footer__col" aria-label="About">
        <h2 class="abe-footer__heading">Company</h2>
        <ul class="abe-footer__list">
          <li><a href="/about">About ABE</a></li>
          <li><a href="/contact">Contact</a></li>
          <li><a href="/faq">FAQ</a></li>
          <li><a href="/blog">Blog</a></li>
        </ul>
      </nav>

      <div class="abe-footer__col">
        <h2 class="abe-footer__heading">Approved by</h2>
        <ul class="abe-footer__list abe-footer__list--muted">
          {REGULATOR_RECOGNITIONS.map((r) => (
            <li><a href={r.url} rel="external noopener">{r.name}</a></li>
          ))}
        </ul>
      </div>
    </div>

    <div class="abe-footer__disclosure">
      <p>
        <strong>ABE Education is a content provider, not a Registered
        Training Organisation (RTO).</strong> For courses leading to
        nationally recognised qualifications, ABE partners with registered
        RTOs who deliver and assess the accredited components:
        {RTO_PARTNERS.filter((p) => !p.name.startsWith('TODO')).length > 0 ? (
          <span>
            {RTO_PARTNERS.filter((p) => !p.name.startsWith('TODO')).map((p, i, arr) => (
              <>
                <a href={p.url} rel="external noopener">{p.name} (RTO {p.rtoCode})</a>{i < arr.length - 1 ? ', ' : ''}
              </>
            ))}.
          </span>
        ) : (
          <span>RTO partner details to be confirmed.</span>
        )}
        State-based Owner Builder courses (e.g. NSW, QLD, WA) are
        non-accredited CPD approved directly by the relevant state
        regulator.
      </p>
    </div>

    <div class="abe-footer__legal">
      <div class="abe-footer__legal-left">
        &copy; {year} {SITE.legalName}. ABN {SITE.abn}.
      </div>
      <ul class="abe-footer__legal-links">
        <li><a href="/privacy">Privacy</a></li>
        <li><a href="/terms">Terms</a></li>
        <li><a href="/refund-policy">Refund policy</a></li>
        <li><a href="/accessibility">Accessibility</a></li>
      </ul>
    </div>
  </div>
</footer>

<style>
  .abe-footer {
    background: var(--color-bg-subtle, #f6f3f0);
    border-top: 4px solid var(--color-maroon-700, #800000);
    color: var(--text-body, #1a1a1a);
    font-family: var(--font-body, 'DM Sans', sans-serif);
  }
  .abe-footer__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: var(--space-64, 64px) var(--space-24, 24px) var(--space-32, 32px);
  }

  .abe-footer__grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1.5fr;
    gap: var(--space-48, 48px);
  }
  @media (max-width: 900px) {
    .abe-footer__grid {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-32, 32px);
    }
    .abe-footer__col--brand { grid-column: 1 / -1; }
  }
  @media (max-width: 560px) {
    .abe-footer__grid { grid-template-columns: 1fr; }
  }

  .abe-footer__logo {
    display: inline-flex;
    align-items: baseline;
    gap: 6px;
    font-family: var(--font-heading, 'Archivo', sans-serif);
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--color-maroon-700, #800000);
    margin-bottom: var(--space-12, 12px);
  }
  .abe-footer__logo-text { font-size: 28px; line-height: 1; }
  .abe-footer__logo-sub {
    font-size: 15px;
    font-weight: 500;
    color: var(--text-subtle, #444);
  }
  .abe-footer__tagline {
    font-size: 15px;
    line-height: 1.55;
    margin: 0 0 var(--space-16, 16px);
    color: var(--text-subtle, #444);
    max-width: 40ch;
  }
  .abe-footer__contact {
    font-style: normal;
    font-size: 14px;
    line-height: 1.6;
  }
  .abe-footer__contact a {
    color: var(--color-maroon-700, #800000);
    text-decoration: none;
    font-weight: 600;
  }
  .abe-footer__contact a:hover { text-decoration: underline; }

  .abe-footer__heading {
    font-family: var(--font-heading, 'Archivo', sans-serif);
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-maroon-700, #800000);
    margin: 0 0 var(--space-16, 16px);
  }
  .abe-footer__list {
    list-style: none;
    margin: 0;
    padding: 0;
    font-size: 14px;
    line-height: 1.9;
  }
  .abe-footer__list a {
    color: var(--text-body, #1a1a1a);
    text-decoration: none;
  }
  .abe-footer__list a:hover {
    color: var(--color-maroon-700, #800000);
    text-decoration: underline;
  }
  .abe-footer__list--muted a { color: var(--text-subtle, #444); }

  .abe-footer__disclosure {
    margin-top: var(--space-48, 48px);
    padding-top: var(--space-24, 24px);
    border-top: 1px solid var(--border-subtle, rgba(0, 0, 0, 0.1));
    font-size: 13px;
    line-height: 1.6;
    color: var(--text-subtle, #444);
  }
  .abe-footer__disclosure strong {
    color: var(--text-body, #1a1a1a);
    font-weight: 600;
  }
  .abe-footer__disclosure a {
    color: var(--color-maroon-700, #800000);
    text-decoration: underline;
  }

  .abe-footer__legal {
    margin-top: var(--space-24, 24px);
    padding-top: var(--space-16, 16px);
    border-top: 1px solid var(--border-subtle, rgba(0, 0, 0, 0.08));
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: var(--space-12, 12px);
    font-size: 12px;
    color: var(--text-subtle, #444);
  }
  .abe-footer__legal-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-16, 16px);
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .abe-footer__legal-links a {
    color: var(--text-subtle, #444);
    text-decoration: none;
  }
  .abe-footer__legal-links a:hover {
    color: var(--color-maroon-700, #800000);
    text-decoration: underline;
  }
</style>
