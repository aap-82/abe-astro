---
// EyebrowLabel — tiny tracked-out uppercase heading used as a section
// eyebrow throughout the Framer /experts treatment. 12 px / Archivo 700,
// 2 px letter-spacing, maroon by default. On dark sections, set
// `tone="gold"` to switch to the safety-gold accent.

export interface Props {
  /** "maroon" (default, light backgrounds) or "gold" (dark backgrounds). */
  tone?: 'maroon' | 'gold';
  /** Extra class hook for positioning overrides. */
  class?: string;
}

const { tone = 'maroon', class: className = '' } = Astro.props;
const classes = ['abe-eyebrow', `abe-eyebrow--${tone}`, className].filter(Boolean).join(' ');
---

<span class={classes}>
  <slot />
</span>

<style>
  .abe-eyebrow {
    display: inline-block;
    font-family: var(--font-heading);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    line-height: 1;
  }
  .abe-eyebrow--maroon { color: var(--color-maroon-700); }
  .abe-eyebrow--gold   { color: var(--color-gold-safety); }
</style>
