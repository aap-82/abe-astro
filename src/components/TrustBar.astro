---
// TrustBar — dark navy horizontal strip of credibility signals.
// Sits above the breadcrumb, directly below the site header.
// Each item: inline SVG icon (stroked gold) + stacked label/sub.
// Kept zero-JS; icons are passed in via props as small symbolic names
// ("check", "clock", "shield", "award") and rendered from a local map.

export interface TrustItem {
  /** One of the built-in icon names below. */
  icon:  'check' | 'clock' | 'shield' | 'award' | 'star' | 'lock';
  label: string;
  sub?:  string;
}

export interface Props {
  items: TrustItem[];
  /** Extra class hook. */
  class?: string;
}

const { items, class: className = '' } = Astro.props;

const ICONS: Record<TrustItem['icon'], string> = {
  check:  '<path d="M4 12l5 5 11-11"/>',
  clock:  '<circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/>',
  shield: '<path d="M12 3l8 3v6c0 4.5-3.5 8-8 9-4.5-1-8-4.5-8-9V6l8-3z"/>',
  award:  '<circle cx="12" cy="9" r="6"/><path d="M9 14l-2 7 5-3 5 3-2-7"/>',
  star:   '<path d="M12 3l2.6 5.8 6.4.6-4.8 4.4 1.4 6.2L12 17.3l-5.6 2.7 1.4-6.2L3 9.4l6.4-.6L12 3z"/>',
  lock:   '<rect x="5" y="11" width="14" height="9" rx="1.5"/><path d="M8 11V8a4 4 0 1 1 8 0v3"/>'
};

const classes = ['abe-trustbar', className].filter(Boolean).join(' ');
---

<aside class={classes} role="region" aria-label="Trust signals">
  <div class="abe-trustbar__inner">
    {items.map((t) => (
      <div class="abe-trustbar__item">
        <svg class="abe-trustbar__icon" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={ICONS[t.icon]} />
        <span class="abe-trustbar__text">
          <span class="abe-trustbar__label">{t.label}</span>
          {t.sub && <span class="abe-trustbar__sub">{t.sub}</span>}
        </span>
      </div>
    ))}
  </div>
</aside>

<style>
  .abe-trustbar {
    background: var(--color-navy-trust);
    color: #ffffff;
  }
  .abe-trustbar__inner {
    max-width: var(--container-editorial);
    margin: 0 auto;
    padding: var(--space-16) var(--space-24);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-around;
    gap: var(--space-24);
  }
  .abe-trustbar__item {
    display: inline-flex;
    align-items: center;
    gap: var(--space-12);
  }
  .abe-trustbar__icon {
    color: var(--color-gold-safety);
    flex: 0 0 auto;
  }
  .abe-trustbar__text {
    display: flex;
    flex-direction: column;
    gap: 2px;
    line-height: 1.2;
  }
  .abe-trustbar__label {
    font-family: var(--font-heading);
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.1px;
    color: #ffffff;
  }
  .abe-trustbar__sub {
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.65);
  }
  @media (max-width: 640px) {
    .abe-trustbar__inner {
      justify-content: flex-start;
      gap: var(--space-16);
    }
  }
</style>
