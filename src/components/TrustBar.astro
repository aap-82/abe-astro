---
// TrustBar — dark navy horizontal strip of credibility signals.
// Two-line format per item: bold white label over smaller grey sub.
// Gold-stroked inline SVG icon sits to the left of the text stack.
// Zero JS. Icons come from a local name map; you can also pass a raw
// SVG inner-markup string via `iconSvg` to override the built-in.

export interface TrustItem {
  /** Built-in icon name. Ignored if `iconSvg` is supplied. */
  icon?: 'check' | 'clock' | 'shield' | 'award' | 'star' | 'lock' | 'house' | 'pin';
  /** Raw SVG inner markup (paths, circles, etc.) on a 24x24 viewBox. */
  iconSvg?: string;
  /** Bold top line — the headline signal. */
  label: string;
  /** Lighter supporting line below the label. */
  sub?: string;
}

export interface Props {
  items: TrustItem[];
  /** Extra class hook. */
  class?: string;
}

const { items, class: className = '' } = Astro.props;

const ICONS: Record<NonNullable<TrustItem['icon']>, string> = {
  check:  '<path d="M4 12l5 5 11-11"/>',
  clock:  '<circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/>',
  shield: '<path d="M12 3l8 3v6c0 4.5-3.5 8-8 9-4.5-1-8-4.5-8-9V6l8-3z"/>',
  award:  '<circle cx="12" cy="9" r="6"/><path d="M9 14l-2 7 5-3 5 3-2-7"/>',
  star:   '<path d="M11.525 2.295a.53.53 0 0 1 .95 0l2.31 4.679a2.123 2.123 0 0 0 1.595 1.16l5.166.756a.53.53 0 0 1 .294.904l-3.736 3.638a2.123 2.123 0 0 0-.611 1.878l.882 5.14a.53.53 0 0 1-.771.56l-4.618-2.428a2.122 2.122 0 0 0-1.973 0L6.396 21.01a.53.53 0 0 1-.77-.56l.881-5.139a2.122 2.122 0 0 0-.611-1.879L2.16 9.795a.53.53 0 0 1 .294-.906l5.165-.755a2.122 2.122 0 0 0 1.597-1.16z"/>',
  lock:   '<rect x="5" y="11" width="14" height="9" rx="1.5"/><path d="M8 11V8a4 4 0 1 1 8 0v3"/>',
  house:  '<path d="M10 18v-7"/><path d="M11.12 2.198a2 2 0 0 1 1.76.006l7.866 3.847c.476.233.31.949-.22.949H3.474c-.53 0-.695-.716-.22-.949z"/><path d="M14 18v-7"/><path d="M18 18v-7"/><path d="M3 22h18"/><path d="M6 18v-7"/>',
  pin:    '<path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"/><circle cx="12" cy="10" r="3"/>'
};

function iconMarkup(item: TrustItem): string {
  if (item.iconSvg) return item.iconSvg;
  if (item.icon && ICONS[item.icon]) return ICONS[item.icon];
  return '';
}

const classes = ['abe-trustbar', className].filter(Boolean).join(' ');
---

<aside class={classes} role="region" aria-label="Trust signals">
  <div class="abe-trustbar__inner">
    {items.map((t) => (
      <div class="abe-trustbar__item">
        <svg
          class="abe-trustbar__icon"
          width="26"
          height="26"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.75"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
          set:html={iconMarkup(t)}
        />
        <span class="abe-trustbar__text">
          <span class="abe-trustbar__label">{t.label}</span>
          {t.sub && <span class="abe-trustbar__sub">{t.sub}</span>}
        </span>
      </div>
    ))}
  </div>
</aside>

<style>
  .abe-trustbar {
    background: var(--color-navy-trust);
    color: #ffffff;
  }
  .abe-trustbar__inner {
    max-width: var(--container-editorial);
    margin: 0 auto;
    padding: 18px var(--space-24);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-24);
  }
  .abe-trustbar__item {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    min-width: 0;
  }
  .abe-trustbar__icon {
    color: var(--color-gold-safety);
    flex: 0 0 auto;
  }
  .abe-trustbar__text {
    display: flex;
    flex-direction: column;
    gap: 2px;
    line-height: 1.25;
    min-width: 0;
  }
  .abe-trustbar__label {
    font-family: var(--font-heading);
    font-size: 15px;
    font-weight: 700;
    letter-spacing: 0.1px;
    color: #ffffff;
  }
  .abe-trustbar__sub {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.58);
    letter-spacing: 0.05px;
  }
  @media (max-width: 900px) {
    .abe-trustbar__inner {
      justify-content: flex-start;
      gap: 20px 28px;
    }
    .abe-trustbar__item {
      flex: 1 1 44%;
    }
  }
  @media (max-width: 560px) {
    .abe-trustbar__item {
      flex: 1 1 100%;
    }
    .abe-trustbar__label { font-size: 14px; }
    .abe-trustbar__sub { font-size: 12px; }
  }
</style>
