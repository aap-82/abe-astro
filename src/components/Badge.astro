---
export type BadgeVariant =
  | 'neutral'
  | 'brand'
  | 'success'
  | 'warning'
  | 'danger'
  | 'info'
  | 'outlined';

export interface Props {
  label: string;
  variant?: BadgeVariant;
  class?: string;
}

const { label, variant = 'neutral', class: className = '' } = Astro.props;
---

<span class={`abe-badge abe-badge--${variant} ${className}`}>{label}</span>

<style>
  .abe-badge {
    display: inline-flex;
    align-items: center;
    height: 24px;
    padding: 0 var(--space-12);
    border-radius: var(--radius-full);
    font-family: var(--font-body);
    font-size: 12px;
    line-height: 16px;
    font-weight: 500;
    letter-spacing: 0.01em;
    text-transform: uppercase;
    white-space: nowrap;
    border: 1px solid transparent;
  }

  .abe-badge--neutral  { background: var(--surface-muted);          color: var(--text-body); }
  .abe-badge--brand    { background: var(--color-maroon-100);       color: var(--color-maroon-700); }
  .abe-badge--success  { background: var(--color-success-100);      color: var(--color-success-700); }
  .abe-badge--warning  { background: var(--color-warning-100);      color: var(--color-warning-700); }
  .abe-badge--danger   { background: var(--color-danger-100);       color: var(--color-danger-700); }
  .abe-badge--info     { background: var(--color-info-100);         color: var(--color-info-700); }
  .abe-badge--outlined {
    background: transparent;
    color: var(--text-body);
    border-color: var(--border-subtle);
  }
</style>
