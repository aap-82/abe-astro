---
// Pullquote — editorial quote block with a thick maroon top border and
// a thin cool-border bottom. Used inside long-form sections.

export interface Props {
  /** Who the quote is from (e.g. "Dominic Ogburn, Head of Curriculum"). */
  cite?: string;
  class?: string;
}

const { cite, class: className = '' } = Astro.props;
const classes = ['abe-pullquote', className].filter(Boolean).join(' ');
---

<figure class={classes}>
  <blockquote class="abe-pullquote__quote">
    <slot />
  </blockquote>
  {cite && <figcaption class="abe-pullquote__cite">{cite}</figcaption>}
</figure>

<style>
  .abe-pullquote {
    border-top: 3px solid var(--color-maroon-700);
    border-bottom: 1px solid var(--border-subtle);
    padding: var(--space-24) 0;
    margin: var(--space-32) 0;
  }
  .abe-pullquote__quote {
    font-family: var(--font-body);
    font-size: 20px;
    font-weight: 500;
    line-height: 1.45;
    color: var(--text-body);
    margin: 0;
  }
  .abe-pullquote__cite {
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.2px;
    color: var(--text-subtle);
    margin-top: var(--space-12);
  }
</style>
