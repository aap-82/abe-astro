---
// Route page — WA Owner Builder Course.
// Applies the Framer /experts editorial treatment: navy TrustBar,
// light Breadcrumb with a Last updated stamp, hero, MDX body, FAQ
// under a centred SectionHeader, dark StatementBlock, then bottom
// CTA band. JSON-LD @graph is unchanged — Breadcrumb emits no
// duplicate schema because pageJsonLd already includes it.

import { getEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import Container from '../components/Container.astro';
import Hero from '../components/Hero.astro';
import Accordion from '../components/Accordion.astro';
import CTABand from '../components/CTABand.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';

import Breadcrumb from '../components/Breadcrumb.astro';
import TrustBar from '../components/TrustBar.astro';
import SectionHeader from '../components/SectionHeader.astro';
import StatementBlock from '../components/StatementBlock.astro';
import AnswerCapsule from '../components/AnswerCapsule.astro';

import {
  breadcrumbSchema,
  courseSchema,
  faqSchema,
  personSchema,
  webPageSchema
} from '../lib/schema';
import { getPerson } from '../lib/people';
import { SITE } from '../lib/site';

const PAGE_PATH = '/wa-owner-builder-course';
const PAGE_URL  = `${SITE.url}${PAGE_PATH}`;

const entry = await getEntry('pages', 'wa-owner-builder-course');
if (!entry) {
  throw new Error('Content entry pages/wa-owner-builder-course.mdx not found');
}

const { data } = entry;
const { Content } = await entry.render();

// People on this page.
const developer = getPerson('dominic-ogburn');
const reviewer  = getPerson('warwick-smith');

// Map the plain-string trustBar array to typed items with icons.
// The icon sequence cycles across the four canonical signals:
// approval, cohort, authority, delivery.
const trustIcons: ('check' | 'star' | 'award' | 'clock' | 'shield' | 'lock')[] =
  ['check', 'star', 'award', 'clock'];
const trustItems = (data.trustBar ?? []).map((label, i) => ({
  icon: trustIcons[i % trustIcons.length],
  label
}));

// Breadcrumb items — reshape content-collection breadcrumb to the
// component's Crumb shape (omit href on the final item).
const breadcrumbItems = data.breadcrumb.map((c, i, arr) => ({
  label: c.name,
  href:  i < arr.length - 1 ? c.url : undefined
}));

// JSON-LD — BreadcrumbList included here; pass schema={false} to the
// Breadcrumb component below to avoid double-emission.
const pageJsonLd = [
  breadcrumbSchema(data.breadcrumb),
  webPageSchema({
    url: PAGE_URL,
    name: data.metaTitle,
    description: data.metaDescription,
    dateModified: data.lastUpdated
  }),
  courseSchema({
    url: PAGE_URL,
    name: 'WA Owner Builder Course',
    description:
      'Online knowledge training accepted on LGIRS Form 75 — Approval: Owner-builder. ' +
      'Self-paced, WA-specific content written to the Form 75 knowledge areas. ' +
      'Certificate of Completion issued the same day for attachment to your application.',
    shortDescription: 'LGIRS Form 75 — online, self-paced, same-day certificate.',
    courseMode: 'online',
    timeRequired: 'PT4H',
    accessPeriod: 'P12M',
    inLanguage: 'en-AU',
    typicalAgeRange: '18-',
    teaches: [
      'Legal responsibilities of a WA owner-builder',
      'Building permits and occupancy permits',
      'Engaging and managing tradespeople',
      'Home indemnity insurance obligations',
      'Workplace health and safety on an owner-built site',
      'Record-keeping, inspections, and practical completion',
      'Scope limits of owner building in WA',
      'Selling, renting, or transferring an owner-built property'
    ],
    about: [
      'Owner-builder training',
      'Western Australia building law',
      'LGIRS Form 75'
    ],
    offer: {
      price: 179,
      priceCurrency: 'AUD',
      url: `${SITE.url}/checkout?course=wa-owner-builder`
    },
    credential: {
      name: 'Certificate of Completion — WA Owner Builder Course',
      credentialCategory: 'Certificate',
      recognizedBy: 'LGIRS Form 75 — Western Australia',
      description:
        'Certificate demonstrating completion of the knowledge training accepted ' +
        'under LGIRS Form 75 — Approval: Owner-builder.'
    },
    developerSlug: developer.slug,
    reviewerSlug:  reviewer.slug,
    dateReviewed:  '2026-04-14'
  }),
  personSchema(developer),
  personSchema(reviewer),
  ...(data.faq ? [faqSchema(data.faq.items)] : [])
];
---

<BaseLayout
  title={data.metaTitle}
  description={data.metaDescription}
  path={PAGE_PATH}
  image={data.ogImage}
  noindex={data.noindex}
  jsonLd={pageJsonLd}
>
  <SiteHeader slot="header" currentPath={PAGE_PATH} />

  <!-- Navy trust bar — gold-stroked icons, label + implicit sub -->
  {trustItems.length > 0 && <TrustBar items={trustItems} />}

  <!-- Light breadcrumb with Last updated stamp. Schema is emitted
       separately via pageJsonLd so we suppress it here. -->
  <Breadcrumb items={breadcrumbItems} lastUpdated={data.lastUpdated} schema={false} />

  <!-- Hero — copy still comes from MDX frontmatter -->
  <Hero
    headline={data.h1}
    overline={data.hero?.overline}
    subhead={data.hero?.subhead}
    primaryCtaLabel={data.hero?.primaryCta?.label}
    primaryCtaHref={data.hero?.primaryCta?.href}
    secondaryCtaLabel={data.hero?.secondaryCta?.label}
    secondaryCtaHref={data.hero?.secondaryCta?.href}
    imageSrc={data.hero?.imageSrc}
    imageAlt={data.hero?.imageAlt}
    variant={data.hero?.imageSrc ? 'primary' : 'minimal'}
    surface={data.hero?.surface}
  />

  <!-- Short framing capsule — answers the core question inline,
       uses the Framer "answer capsule" treatment. -->
  <Section surface="subtle" padding="s">
    <Container width="narrow">
      <AnswerCapsule label="The short answer" icon="📌">
        <p>
          <strong>Yes — ABE's online course meets LGIRS Form 75 knowledge requirements.</strong>
          It is self-paced, takes about four hours, and the Certificate of Completion
          is issued the same day for attachment to your owner-builder application.
        </p>
      </AnswerCapsule>
    </Container>
  </Section>

  <!-- Body — MDX renders interleaved component sections (Approvals,
       CourseOutline, Pricing, Callout, PersonCard) alongside prose. -->
  <Section surface="page" padding="m">
    <Container width="narrow">
      <div class="abe-course-prose">
        <Content />
      </div>
    </Container>
  </Section>

  <!-- FAQ under a centred editorial SectionHeader -->
  {data.faq && (
    <Section surface="subtle" padding="m">
      <Container width="narrow">
        <SectionHeader
          eyebrow="Frequently asked"
          title={data.faq.heading}
          lede="Short answers to the questions we hear most from WA owner-builders."
        />
        <Accordion items={data.faq.items} mode="multi" variant="bordered" />
      </Container>
    </Section>
  )}

  <!-- Dark authority statement block — Framer 5fr/7fr charcoal pattern -->
  <StatementBlock
    eyebrow="Why this course"
    title="Written by a licensed builder, reviewed against the current WA Form."
  >
    <p>
      Every module is written by Dominic Ogburn — NSW Builder Licence 369417C,
      forty years of residential construction, and recipient of the 2005 NSW
      Minister's Award. The WA-specific content is checked annually by Warwick Smith
      against the current LGIRS Form 75 and the Building Act 2011 (WA).
    </p>
    <p>
      You are not buying generic Australian compliance content dressed up for WA.
      You are buying a WA course written specifically to the Form 75 knowledge areas.
    </p>
  </StatementBlock>

  <!-- Bottom CTA -->
  {data.ctaBand && (
    <CTABand
      headline={data.ctaBand.headline}
      subhead={data.ctaBand.subhead}
      primaryCtaLabel={data.ctaBand.primaryCta.label}
      primaryCtaHref={data.ctaBand.primaryCta.href}
      secondaryCtaLabel={data.ctaBand.secondaryCta?.label}
      secondaryCtaHref={data.ctaBand.secondaryCta?.href}
      variant={data.ctaBand.variant}
    />
  )}

  <SiteFooter slot="footer" />
</BaseLayout>

<style>
  /* Course prose — scoped so only raw h2/h3/p (class-less) pick up
     editorial styling. Component-rendered headings keep their own
     typography. */
  .abe-course-prose {
    font-family: var(--font-body);
    font-size: 17px;
    line-height: 1.65;
    color: var(--text-body);
  }

  .abe-course-prose :global(h2:not([class])) {
    font-family: var(--font-heading);
    font-size: clamp(24px, 3vw, 32px);
    line-height: 1.25;
    font-weight: 800;
    letter-spacing: -0.5px;
    margin: var(--space-48) 0 var(--space-16);
    padding-top: var(--space-24);
    border-top: 2px solid var(--color-maroon-700);
    color: var(--text-body);
  }
  .abe-course-prose :global(h2:not([class]):first-child) {
    margin-top: 0;
    padding-top: 0;
    border-top: none;
  }
  .abe-course-prose :global(h3:not([class])) {
    font-family: var(--font-heading);
    font-size: 20px;
    line-height: 1.3;
    font-weight: 700;
    margin: var(--space-32) 0 var(--space-12);
    color: var(--text-body);
  }
  .abe-course-prose :global(p) { margin: 0 0 var(--space-16); }
  .abe-course-prose :global(ul),
  .abe-course-prose :global(ol) {
    margin: var(--space-16) 0;
    padding-left: var(--space-24);
  }
  .abe-course-prose :global(li) { margin-bottom: var(--space-8); }
  .abe-course-prose :global(strong) { font-weight: 600; }
  .abe-course-prose :global(a) {
    color: var(--color-maroon-700);
    text-decoration: underline;
    text-decoration-style: dotted;
    text-underline-offset: 3px;
  }
  .abe-course-prose :global(a:hover),
  .abe-course-prose :global(a:focus-visible) {
    color: var(--color-maroon-800);
    text-decoration-style: solid;
  }
</style>
