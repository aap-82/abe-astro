---
// Route page — WA Owner Builder Course.
// Mirrors the about.astro shell pattern: pulls frontmatter + MDX body
// from the content collection, renders the standard page chrome
// (breadcrumb, trust bar, hero, prose body, FAQ, CTA band), and
// appends Course + Person JSON-LD alongside the usual WebPage /
// FAQ / Breadcrumb schemas.
//
// The MDX body uses component imports (Approvals, Pricing,
// CourseOutline, Callout, PersonCard) inline — we do NOT pass those
// as props here; they are imported at the top of the MDX file.

import { getEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import Container from '../components/Container.astro';
import Hero from '../components/Hero.astro';
import Accordion from '../components/Accordion.astro';
import CTABand from '../components/CTABand.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';

import {
  breadcrumbSchema,
  courseSchema,
  faqSchema,
  personSchema,
  webPageSchema
} from '../lib/schema';
import { getPerson } from '../lib/people';
import { SITE } from '../lib/site';

const PAGE_PATH = '/wa-owner-builder-course';
const PAGE_URL  = `${SITE.url}${PAGE_PATH}`;

const entry = await getEntry('pages', 'wa-owner-builder-course');
if (!entry) {
  throw new Error('Content entry pages/wa-owner-builder-course.mdx not found');
}

const { data } = entry;
const { Content } = await entry.render();

// Format the update date for the breadcrumb bar (Australian format)
const updated = new Date(data.lastUpdated).toLocaleDateString('en-AU', {
  year: 'numeric',
  month: 'long'
});

// People attached to this page (must match the slugs used in the
// PersonCard components inside the MDX body).
const developer = getPerson('dominic-ogburn');
const reviewer  = getPerson('warwick-smith');

// Build JSON-LD for this page.
const pageJsonLd = [
  breadcrumbSchema(data.breadcrumb),
  webPageSchema({
    url: PAGE_URL,
    name: data.metaTitle,
    description: data.metaDescription,
    dateModified: data.lastUpdated
  }),
  courseSchema({
    url: PAGE_URL,
    name: 'WA Owner Builder Course',
    description:
      'Online knowledge training accepted on LGIRS Form 75 — Approval: Owner-builder. ' +
      'Self-paced, WA-specific content written to the Form 75 knowledge areas. ' +
      'Certificate of Completion issued the same day for attachment to your application.',
    shortDescription: 'LGIRS Form 75 — online, self-paced, same-day certificate.',
    courseMode: 'online',
    timeRequired: 'PT4H',
    accessPeriod: 'P12M',
    inLanguage: 'en-AU',
    typicalAgeRange: '18-',
    teaches: [
      'Legal responsibilities of a WA owner-builder',
      'Building permits and occupancy permits',
      'Engaging and managing tradespeople',
      'Home indemnity insurance obligations',
      'Workplace health and safety on an owner-built site',
      'Record-keeping, inspections, and practical completion',
      'Scope limits of owner building in WA',
      'Selling, renting, or transferring an owner-built property'
    ],
    about: [
      'Owner-builder training',
      'Western Australia building law',
      'LGIRS Form 75'
    ],
    offer: {
      price: 179,
      priceCurrency: 'AUD',
      url: `${SITE.url}/checkout?course=wa-owner-builder`
    },
    credential: {
      name: 'Certificate of Completion — WA Owner Builder Course',
      credentialCategory: 'Certificate',
      recognizedBy: 'LGIRS Form 75 — Western Australia',
      description:
        'Certificate demonstrating completion of the knowledge training accepted ' +
        'under LGIRS Form 75 — Approval: Owner-builder.'
    },
    developerSlug: developer.slug,
    reviewerSlug:  reviewer.slug,
    dateReviewed:  '2026-04-14'
  }),
  personSchema(developer),
  personSchema(reviewer),
  ...(data.faq ? [faqSchema(data.faq.items)] : [])
];
---

<BaseLayout
  title={data.metaTitle}
  description={data.metaDescription}
  path={PAGE_PATH}
  image={data.ogImage}
  noindex={data.noindex}
  jsonLd={pageJsonLd}
>
  <SiteHeader slot="header" currentPath={PAGE_PATH} />

  <!-- Breadcrumb bar -->
  <Section surface="subtle" padding="s" class="abe-breadcrumb">
    <Container width="content">
      <nav aria-label="Breadcrumb" class="abe-breadcrumb__nav">
        <ol class="abe-breadcrumb__list">
          {data.breadcrumb.map((crumb, i) => (
            <li class="abe-breadcrumb__item">
              {i < data.breadcrumb.length - 1 ? (
                <a href={crumb.url}>{crumb.name}</a>
              ) : (
                <span aria-current="page">{crumb.name}</span>
              )}
              {i < data.breadcrumb.length - 1 && <span class="abe-breadcrumb__sep"> › </span>}
            </li>
          ))}
        </ol>
        <span class="abe-breadcrumb__updated">Last updated: {updated}</span>
      </nav>
    </Container>
  </Section>

  <!-- Trust bar -->
  {data.trustBar && (
    <Section surface="brand-tint" padding="s" class="abe-trustbar">
      <Container width="wide">
        <ul class="abe-trustbar__list" role="list">
          {data.trustBar.map((item) => (
            <li class="abe-trustbar__item">{item}</li>
          ))}
        </ul>
      </Container>
    </Section>
  )}

  <!-- Hero — H1 comes from MDX frontmatter -->
  <Hero
    headline={data.h1}
    overline={data.hero?.overline}
    subhead={data.hero?.subhead}
    primaryCtaLabel={data.hero?.primaryCta?.label}
    primaryCtaHref={data.hero?.primaryCta?.href}
    secondaryCtaLabel={data.hero?.secondaryCta?.label}
    secondaryCtaHref={data.hero?.secondaryCta?.href}
    imageSrc={data.hero?.imageSrc}
    imageAlt={data.hero?.imageAlt}
    variant={data.hero?.imageSrc ? 'primary' : 'minimal'}
    surface={data.hero?.surface}
  />

  <!-- Body — the MDX renders its own component sections (Approvals,
       CourseOutline, Pricing, Callout, PersonCard) interleaved with
       prose. The .abe-course-prose wrapper only styles raw h2/h3/p
       nodes (class-less), so component headings keep their own
       typography. -->
  <Section surface="page" padding="m">
    <Container width="narrow">
      <div class="abe-course-prose">
        <Content />
      </div>
    </Container>
  </Section>

  <!-- FAQ -->
  {data.faq && (
    <Section surface="subtle" padding="m">
      <Container width="narrow">
        <h2 class="abe-faq__heading">{data.faq.heading}</h2>
        <Accordion items={data.faq.items} mode="multi" variant="bordered" />
      </Container>
    </Section>
  )}

  <!-- Bottom CTA -->
  {data.ctaBand && (
    <CTABand
      headline={data.ctaBand.headline}
      subhead={data.ctaBand.subhead}
      primaryCtaLabel={data.ctaBand.primaryCta.label}
      primaryCtaHref={data.ctaBand.primaryCta.href}
      secondaryCtaLabel={data.ctaBand.secondaryCta?.label}
      secondaryCtaHref={data.ctaBand.secondaryCta?.href}
      variant={data.ctaBand.variant}
    />
  )}

  <SiteFooter slot="footer" />
</BaseLayout>

<style>
  /* Breadcrumb */
  .abe-breadcrumb__nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-16);
    flex-wrap: wrap;
    font-family: var(--font-body);
    font-size: 14px;
    line-height: 20px;
    color: var(--text-subtle);
  }
  .abe-breadcrumb__list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .abe-breadcrumb__item { margin: 0; }
  .abe-breadcrumb__sep {
    color: var(--text-muted);
    margin-inline: var(--space-4);
  }
  .abe-breadcrumb__updated {
    font-size: 12px;
    color: var(--text-muted);
  }

  /* Trust bar */
  .abe-trustbar__list {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-16) var(--space-32);
    margin: 0;
    padding: 0;
    list-style: none;
    font-family: var(--font-body);
    font-size: 14px;
    line-height: 20px;
    font-weight: 600;
    color: var(--text-body);
  }
  .abe-trustbar__item {
    margin: 0;
    white-space: nowrap;
  }
  .abe-trustbar__item::before {
    content: '✓';
    color: var(--color-maroon-700);
    font-weight: 700;
    margin-right: var(--space-8);
  }

  /* Course prose — intentionally narrower selectors than .abe-prose
     so that component-rendered h2/h3/p nodes (Approvals, Pricing,
     CourseOutline, Callout, PersonCard) are not restyled. */
  .abe-course-prose {
    font-family: var(--font-body);
    font-size: 17px;
    line-height: 1.65;
    color: var(--text-body);
  }

  .abe-course-prose :global(h2:not([class])) {
    font-family: var(--font-heading);
    font-size: clamp(24px, 3vw, 32px);
    line-height: 1.25;
    font-weight: 700;
    letter-spacing: -0.01em;
    margin: var(--space-48) 0 var(--space-16);
    padding-top: var(--space-24);
    border-top: 2px solid var(--color-maroon-700);
    color: var(--text-body);
  }
  .abe-course-prose :global(h2:not([class]):first-child) {
    margin-top: 0;
    padding-top: 0;
    border-top: none;
  }
  .abe-course-prose :global(h3:not([class])) {
    font-family: var(--font-heading);
    font-size: 20px;
    line-height: 28px;
    font-weight: 700;
    margin: var(--space-32) 0 var(--space-12);
    color: var(--text-body);
  }
  .abe-course-prose :global(p) { margin: 0 0 var(--space-16); }
  .abe-course-prose :global(ul),
  .abe-course-prose :global(ol) {
    margin: var(--space-16) 0;
    padding-left: var(--space-24);
  }
  .abe-course-prose :global(li) {
    margin-bottom: var(--space-8);
  }
  .abe-course-prose :global(strong) { font-weight: 600; }
  .abe-course-prose :global(a) {
    color: var(--color-maroon-700);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .abe-course-prose :global(a:hover),
  .abe-course-prose :global(a:focus-visible) {
    color: var(--color-maroon-800);
  }

  /* FAQ heading */
  .abe-faq__heading {
    font-family: var(--font-heading);
    font-size: clamp(28px, 4vw, 36px);
    line-height: 1.2;
    font-weight: 700;
    letter-spacing: -0.01em;
    margin: 0 0 var(--space-32);
    text-align: center;
  }
</style>
